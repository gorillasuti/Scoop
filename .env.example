# Database connection url (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/database_name?schema=public"

# NextAuth configuration
# You can generate a secret via: openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# Web Push Notifications (VAPID keys)
# You can generate these using 'npx web-push generate-vapid-keys'
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your_vapid_public_key_here"
VAPID_PRIVATE_KEY="your_vapid_private_key_here"
VAPID_EMAIL="mailto:your_email@example.com"

# Allowed development origins for hot-reloads/websockets (optional)
ALLOWED_DEV_ORIGINS="localhost"
